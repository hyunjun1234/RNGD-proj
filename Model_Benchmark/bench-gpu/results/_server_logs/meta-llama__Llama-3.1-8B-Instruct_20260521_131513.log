y\'.ljust(col0_len)\n1609             + \'   \' + \'Description\'.ljust(col1_len),\n1610             table_formatstr,\n1611             *[pad + \'   \' + n.ljust(col0_len) + \'   \' + a.ljust(col1_len)\n1612               for n, a in zip(names, accepts)],\n1613             table_formatstr,\n1614             \'\',\n1615         ]\n1616 \n1617     def properties(self):\n1618         """Return a dictionary mapping property name -> value."""\n1619         o = self.oorig\n1620         getters = [name for name in dir(o)\n1621                    if name.startswith(\'get_\') and callable(getattr(o, name))]\n1622         getters.sort()\n1623         d = {}\n1624         for name in getters:\n1625             func = getattr(o, name)\n1626             if self.is_alias(func):\n1627                 continue\n1628             try:\n1629                 with warnings.catch_warnings():\n1630                     warnings.simplefilter(\'ignore\')\n1631                     val = func()\n1632             except Exception:\n1633                 continue\n1634             else:\n1635                 d[name[4:]] = val\n1636         return d\n1637 \n1638     def pprint_getters(self):\n1639         """Return the getters and actual values as list of strings."""\n1640         lines = []\n1641         for name, val in sorted(self.properties().items()):\n1642             if getattr(val, \'shape\', ()) != () and len(val) > 6:\n1643                 s = str(val[:6]) + \'...\'\n1644             else:\n1645                 s = str(val)\n1646             s = s.replace(\'\\n\', \' \')\n1647             if len(s) > 50:\n1648                 s = s[:50] + \'...\'\n1649             name = self.aliased_name(name)\n1650             lines.append(\'    %s = %s\' % (name, s))\n1651         return lines\n1652 \n1653 \n1654 def getp(obj, property=None):\n1655     """\n1656     Return the value of an `.Artist`\'s *property*, or print all of them.\n1657 \n1658     Parameters\n1659     ----------\n1660     obj : `.